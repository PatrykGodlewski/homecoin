package errors

import "github.com/godlew/homecoin/internal/ui/views/layouts"

templ Error404() {
	@layouts.BaseLayout() {
		<div class="auth-wrap">
			<div class="auth-card" style="text-align: center;">
				<h1 style="font-size: 3rem; margin-bottom: 0.5rem;">404</h1>
				<p class="subtitle">The page you are looking for does not exist.</p>
				<a href="/dashboard" class="btn btn-primary" style="margin-top: 1rem;">Go to dashboard</a>
			</div>
		</div>
	}
}
